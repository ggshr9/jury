# Copy to .env and fill in. Commit .env.example, not .env.
# Any reviewer whose key is missing is silently skipped at runtime.

# Anthropic API (Claude Sonnet 4.6 / Opus)
ANTHROPIC_API_KEY=

# DeepSeek direct API (found in compass/llm/src/config/index.ts comments)
DEEPSEEK_API_KEY=

# Kimi on-prem at 10.84.10.22:8003 (compass's production LLM)
# Works only on company network.
COMPASS_LLM_ONPREM_KEY=
# Optional override if you want to point at a different Kimi endpoint:
# KIMI_BASE_URL=http://10.84.10.22:8003

# ZenMux aggregator — provides access to GPT-5.4 / Gemini / etc. via a
# single OpenAI-compatible API. Cheaper and faster than Codex CLI for
# bulk runs.
ZENMUX_API_KEY=
